{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Vehicles MS",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run start -- --debug 9230 --watch",
      "cwd": "${workspaceFolder}/vehicles-ms"
    },
    {
      "name": "Debug API Gateway",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run start -- --debug 9231 --watch",
      "cwd": "${workspaceFolder}/api-gateway"
    },
    {
      "name": "Debug API Gateway (dev)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run start -- --debug 9231 --watch",
      "cwd": "${workspaceFolder}/api-gateway",
      "env": {
        "DOTENV_CONFIG_PATH": ".env.dev"
      }
    },
    {
      "name": "Debug Events MS",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run start -- --debug 9232 --watch",
      "cwd": "${workspaceFolder}/events-ms"
    },
    {
      "name": "Debug Users MS",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run start -- --debug 9233 --watch",
      "cwd": "${workspaceFolder}/users-ms"
    },
    {
      "name": "Debug Maintenances MS",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run start -- --debug 9234 --watch",
      "cwd": "${workspaceFolder}/maintenances-ms"
    },
    {
      "name": "Debug Notifications MS",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run start -- --debug 9235 --watch",
      "cwd": "${workspaceFolder}/notifications-ms"
    }
  ],
  "compounds": [
    {
      "name": "Debug All Services",
      "configurations": [
        "Debug Vehicles MS",
        "Debug API Gateway",
        "Debug Events MS",
        "Debug Users MS",
        "Debug Maintenances MS",
        "Debug Notifications MS"
      ]
    },
    {
      "name": "Debug All Services (dev)",
      "configurations": [
        "Debug Vehicles MS",
        "Debug API Gateway (dev)",
        "Debug Events MS",
        "Debug Users MS",
        "Debug Maintenances MS",
        "Debug Notifications MS"
      ]
    }
  ]
}
